# .env.example — Kairos Agent
# ──────────────────────────────────────────────────────────────
# This file is an OPTIONAL fallback for running sync.py directly
# from the command line (dev/CLI use only).
#
# Primary path: the setup wizard copies tiger_openapi_config.properties
# to ~/.kairos-agent/ automatically. If that file exists, these env
# vars are NOT needed and are ignored.
#
# Copy this to .env and fill in your values ONLY if you are running
# sync.py directly without the app.
#
# NEVER commit .env to GitHub — it is gitignored.
# ──────────────────────────────────────────────────────────────

# ── Tiger (non-secret config) ─────────────────────────────────
# Find these in your tiger_openapi_config.properties file.
# The private key is read from the properties file automatically.
TIGER_ID=your_tiger_id
TIGER_ACCOUNT=your_account_number
TIGER_LICENSE=TBSG
TIGER_ENV=PROD

# ── Moomoo ────────────────────────────────────────────────────
# Moomoo connects via OpenD on localhost — no env vars needed.
# Ensure OpenD is running before syncing.

# ── Optix signal tagging ──────────────────────────────────────
# URL of your Kairos portal. When set, sync will look up the
# closest Optix signal within ±2 hours of each trade entry and
# tag it with signal_tier, signal_score, regime_at_entry.
# Leave blank to skip tagging (trades marked untagged in portal).
KAIROS_PORTAL_URL=https://your-portal.pages.dev
